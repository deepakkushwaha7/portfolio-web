# ============================================================
# .env.example — copy to .env and fill in real values.
# Never commit the real .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
# Comma-separated list — no trailing slashes
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ------------------------------------------------------------
# Database
# Locally: leave blank to use SQLite.
# Production: set a full PostgreSQL connection URL.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# ------------------------------------------------------------
DATABASE_URL=postgres://portfolio_user:supersecret@localhost:5432/portfolio_db

# ------------------------------------------------------------
# Redis (used for caching AND as Celery broker)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# AWS S3 (leave blank to serve media from local disk in dev)
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# ------------------------------------------------------------
# Email — SendGrid
# Leave SENDGRID_API_KEY blank to use console email backend in dev.
# ------------------------------------------------------------
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@deepakkushwaha.com
ADMIN_EMAIL=kdeepakkushwaha@gmail.com

# ------------------------------------------------------------
# CORS — comma-separated frontend origins (no trailing slashes)
# ------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://deepakkushwaha.com

# ------------------------------------------------------------
# PhonePe Payment Gateway
# Obtain from the PhonePe merchant dashboard.
# ------------------------------------------------------------
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
# Set to "PRODUCTION" or "UAT"
PHONEPE_ENV=UAT

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
DJANGO_LOG_LEVEL=INFO

# ------------------------------------------------------------
# Database SSL mode (prefer | require | disable)
# ------------------------------------------------------------
DB_SSLMODE=prefer
