frontend/.env.*.local
backend/.env
backend/.env.*
!backend/.env.example
!frontend/.env.local.example

# ── Python ────────────────────────────────────────────────────────────────────
venv/
env/
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ── Django ────────────────────────────────────────────────────────────────────
backend/db.sqlite3
backend/media/
backend/staticfiles/

# ── Node / Next.js ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/npm-debug.log*

